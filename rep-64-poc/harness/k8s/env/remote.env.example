# Remote-tier env profile — copy to env/remote.env (gitignored) and edit for
# your cluster. Keep this file as the committed template; never put real
# context names or namespaces into it.
#
# Workflow:
#   cp env/remote.env.example env/remote.env
#   $EDITOR env/remote.env                                   # fill in the blanks
#   export HARNESS_ENV_FILE=rep-64-poc/harness/k8s/env/remote.env
#   scripts/run-all.sh --tier=remote                         # preflight + tests
#
# The harness never creates or destroys remote clusters — bring-up, scaling,
# and tear-down are the cluster operator's responsibility.

# --- Cluster identity ---
# Whatever shows up under `kubectl config current-context` for your cluster.
KUBE_CONTEXT=your-remote-context
# Namespace where you have RayCluster/PVC/ConfigMap/Job/pods/exec rights.
# 00-check-remote.sh verifies the RBAC matrix; failures abort before deploy.
NAMESPACE=your-namespace

# --- Image ---
# Public rep-64 image; confirm your cluster can pull from ghcr.io. If not,
# push to a registry your cluster trusts (or have an operator do it) and
# update IMAGE accordingly. Image content matches build-image.sh output.
IMAGE=ghcr.io/jhasm/ray-rocksdb-poc:rep-64-poc
# Remote tiers pull from a registry, unlike k3d which uses `k3d image import`.
IMAGE_PULL_POLICY=IfNotPresent

# --- Workload sizing (tune for your cluster's quotas) ---
# K8s container request/limit for the head pod (gcs_server + raylet need this).
HEAD_CPU=2
# Ray-scheduler-visible CPU on the head; 0 keeps user actors off the head pod
# so 30-pod-delete tests durability rather than worker-process co-location.
HEAD_RAY_CPU=0
HEAD_MEMORY=4Gi
# Multi-host clusters can afford a real worker pool; bump if you want more.
WORKER_REPLICAS=2
WORKER_CPU=2
WORKER_MEMORY=4Gi

# --- Storage ---
# Default StorageClass for the GCS PVC. Find candidates with `kubectl get sc`.
# Empty string is rejected by 00-check-remote.sh — set it explicitly.
STORAGE_CLASS=
PVC_SIZE=10Gi
# Optional substrate sweep — csv list of StorageClasses to fsync-probe via
# 40-substrate-sweep.sh. Leave empty to skip.
SUBSTRATE_SWEEP_CLASSES=
# Optional fast-NVMe class for 50-fast-storage.sh. Leave empty to skip.
FAST_NVME_CLASS=

# --- Test workload ---
ACTOR_COUNT=10
MICROBENCH_KEY_COUNT=10000
PIPELINE_BENCH_IO_POOL_SIZES="1 2 4 8"
# Default OFF on remote — the inmem-vs-rocksdb contrast already lives in the
# canonical k3d baseline. Flip to 1 if you want it run on this cluster too.
BASELINE_INMEM=0
DEPLOY_TIMEOUT_S=600
POD_RESTART_TIMEOUT_S=300

# --- Output ---
RESULTS_DIR=rep-64-poc/harness/k8s/results/remote

# --- Backend selection (used by 10-deploy-cluster.sh) ---
# "rocksdb" (persist to PV) or "memory" (in-memory, lost on restart).
# 30-pod-delete.sh overrides this internally when running the inmem baseline.
GCS_STORAGE=rocksdb
