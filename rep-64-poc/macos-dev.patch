+// media-flush barrier. We open the DB directory once and reuse the
+// fd; the call applies to the drive globally, regardless of which fd
+// is used.
+class FullFsyncBarrier {
+ public:
+  FullFsyncBarrier() : fd_(-1) {}
+  bool Open(const std::string &dir) {
+    fd_ = ::open(dir.c_str(), O_RDONLY);
+    return fd_ >= 0;
+  }
+  // Returns 0 on success.
+  int Issue() const { return ::fcntl(fd_, F_FULLFSYNC, 0); }
+  ~FullFsyncBarrier() {
+    if (fd_ >= 0) ::close(fd_);
+  }
+
+ private:
+  int fd_;
+};
+#endif
