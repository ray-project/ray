# Python requirements to run release tests from anyscale byod (cpu type)

locust==2.44.3
# gevent 25.9.1 has a monkey-patch regression that infinitely recurses in the
# ssl SSLContext.minimum_version setter (RecursionError on import of locust ->
# urllib3) on py3.14. locust caps gevent <26.0.0, so pin to the last good
# release before the regression. Remove once locust allows a fixed gevent 26.x.
