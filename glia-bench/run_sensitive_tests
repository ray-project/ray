#!/usr/bin/env bash
# Run the determinism-sensitive test suite N times (default 3).
#
# These tests encode user-facing contracts Ray Data advertises (e.g. seeded
# local shuffle reproducibility). They are not "flaky": they pass reliably
# against a scheduler that keeps block arrival order deterministic. They
# fail probabilistically under timing-sensitive optimizations.
#
# A single pass of such a test is NOT evidence that your optimization is
# safe — a bug with 50% per-run pass probability passes half the time. Run
# them N times (we default to 3) and treat any single failure as a real
# regression.
#
# Usage:
#   ./evaluator/run_sensitive_tests            # N=3
#   ./evaluator/run_sensitive_tests 5          # N=5
#   ./evaluator/run_sensitive_tests 10         # N=10 (stricter, ~1-2 min)
#
# Exit code:
#   0  — all sensitive tests passed on all N runs
#   1  — at least one run of one test failed

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ARTIFACT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
N="${1:-3}"

export RAY_OBJECT_STORE_ALLOW_SLOW_STORAGE="${RAY_OBJECT_STORE_ALLOW_SLOW_STORAGE:-1}"
export RAY_DATA_DISABLE_PROGRESS_BARS="${RAY_DATA_DISABLE_PROGRESS_BARS:-1}"

cd "$ARTIFACT_DIR"

python3 - "$N" "$SCRIPT_DIR" <<'PY'
import sys, os, json, tempfile

n_runs = int(sys.argv[1])
evaluator_dir = sys.argv[2]
sys.path.insert(0, evaluator_dir)
from test_list import SENSITIVE_TESTS
from run_gated_tests import _run_sensitive_tests

artifact_dir = os.path.abspath(".")

print(f"Running {len(SENSITIVE_TESTS)} sensitive test(s) {n_runs}x each:", file=sys.stderr)
for t in SENSITIVE_TESTS:
    print(f"  - {t}", file=sys.stderr)
print(file=sys.stderr)

results = _run_sensitive_tests(artifact_dir, timeout_per_test=180, n_runs=n_runs)

any_failed = False
print(json.dumps({
    "n_runs": n_runs,
    "results": results,
}, indent=2))
for test, status in results.items():
    if status != "passed":
        any_failed = True

if any_failed:
    print(
        "\nAt least one sensitive test failed on at least one run. "
        "This is NOT a flaky test — it indicates your change affects "
        "determinism. Investigate before committing.",
        file=sys.stderr,
    )
    sys.exit(1)
else:
    print(
        f"\nAll sensitive tests passed on all {n_runs} runs.",
        file=sys.stderr,
    )
PY
