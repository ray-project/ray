diff --git src/crypto/internal.h src/crypto/internal.h
--- src/crypto/internal.h
+++ src/crypto/internal.h
@@ -133,8 +133,20 @@
 // Such flags can be removed. If building with MSVC, build with /std:c11.
 #error "BoringSSL must be built in C11 mode or higher."
