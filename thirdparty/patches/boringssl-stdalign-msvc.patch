-#include <stdalign.h>
+#if !defined(_MSC_VER)
+#include <stdalign.h>
+#else
+// VS 2019 and earlier do not ship stdalign.h (added in VS 2022).  MSVC
+// supports _Alignas/_Alignof as keywords in /std:c11 mode, so provide the
+// C11 convenience macros manually instead of including the missing header.
+#ifndef alignas
+#define alignas _Alignas
+#endif
+#ifndef alignof
+#define alignof _Alignof
+#endif
+#endif
 #endif
 
