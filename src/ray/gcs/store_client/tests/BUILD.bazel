load("//bazel:ray.bzl", "ray_cc_library", "ray_cc_test")

ray_cc_library(
    name = "store_client_test_lib",
    hdrs = ["store_client_test_base.h"],
    deps = [
        "//src/ray/common:test_utils",
        "//src/ray/gcs/store_client",
        "//src/ray/observability:fake_metric",
    ],
)

ray_cc_test(
    name = "redis_store_client_test",
    size = "small",
    srcs = ["redis_store_client_test.cc"],
    data = [
        "//:redis-cli",
        "//:redis-server",
    ],
    env = {
        "TEST_REDIS_SERVER_EXEC_PATH": "$(rootpath //:redis-server)",
        "TEST_REDIS_CLIENT_EXEC_PATH": "$(rootpath //:redis-cli)",
    },
    tags = ["team:core"],
    deps = [
        ":store_client_test_lib",
        "//src/ray/gcs/store_client:redis_store_client",
        "//src/ray/util:network_util",
        "//src/ray/util:path_utils",
        "//src/ray/util:raii",
        "@boost//:optional",
    ],
)

ray_cc_test(
    name = "chaos_redis_store_client_test",
    size = "small",
    srcs = ["redis_store_client_test.cc"],
    data = [
        "//:redis-cli",
        "//:redis-server",
    ],
    env = {
        "REDIS_CHAOS": "1",
        "TEST_REDIS_SERVER_EXEC_PATH": "$(rootpath //:redis-server)",
        "TEST_REDIS_CLIENT_EXEC_PATH": "$(rootpath //:redis-cli)",
    },
    tags = [
        "no_windows",
        "team:core",
    ],
    target_compatible_with = [
        "@platforms//os:linux",
    ],
    deps = [
        ":store_client_test_lib",
        "//src/ray/gcs/store_client:redis_store_client",
        "//src/ray/util:network_util",
        "//src/ray/util:path_utils",
        "//src/ray/util:raii",
        "@boost//:optional",
    ],
)

ray_cc_test(
    name = "in_memory_store_client_test",
    size = "small",
    srcs = ["in_memory_store_client_test.cc"],
    tags = ["team:core"],
    deps = [
        ":store_client_test_lib",
        "//src/ray/gcs/store_client:in_memory_store_client",
    ],
)

# REP-64 (rep-64-poc/) Phase 2 smoke test: opens a RocksDB directly,
# proves the dep is wired in. Does NOT use StoreClient.
ray_cc_test(
    name = "rocksdb_smoke_test",
    size = "small",
    srcs = ["rocksdb_smoke_test.cc"],
    tags = ["team:core"],
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        "@com_github_facebook_rocksdb//:rocksdb",
    ],
)

# REP-64 Phase 3 walking-skeleton tests: cluster-id marker, recovery
# across close+reopen, JobID monotonicity. Phase-3-specific scenarios
# that don't fit StoreClientTestBase.
ray_cc_test(
    name = "rocksdb_store_client_test",
    size = "small",
    srcs = ["rocksdb_store_client_test.cc"],
    tags = ["team:core"],
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        "//src/ray/common:asio",
        "//src/ray/gcs/store_client:rocksdb_store_client",
    ],
)

ray_cc_test(
    name = "observable_store_client_test",
    size = "small",
    srcs = ["observable_store_client_test.cc"],
    tags = ["team:core"],
    deps = [
        ":store_client_test_lib",
        "//src/ray/gcs/store_client:in_memory_store_client",
        "//src/ray/gcs/store_client:observable_store_client",
        "//src/ray/observability:fake_metric",
    ],
)

ray_cc_test(
