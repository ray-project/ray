proto_library(
    name = "raft_proto",
    srcs = ["raft.proto"],
    deps = [
        "@com_google_protobuf//:any_proto",
        "@com_google_protobuf//:timestamp_proto",
    ],
)

cc_proto_library(
    name = "raft_cc_proto",
    deps = [":raft_proto"],
)

