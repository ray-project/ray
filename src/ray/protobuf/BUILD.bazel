        "@com_google_protobuf//:timestamp_proto",
    ],
)

cc_proto_library(
    name = "gcs_service_cc_proto",
    deps = [":gcs_service_proto"],
)

proto_library(
    name = "gcs_tables_proto",
    srcs = ["gcs_tables.proto"],
    deps = [
        "@com_google_protobuf//:any_proto",
        "@com_google_protobuf//:timestamp_proto",
    ],
)

cc_proto_library(
    name = "gcs_tables_cc_proto",
    deps = [":gcs_tables_proto"],
)

proto_library(
    name = "usage_proto",
