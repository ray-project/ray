ray_cc_library(
    name = "memory_monitor_factory",
    srcs = select({
        "//bazel:is_linux": [
            "multi_memory_monitor_factory.cc",
        ],
        "//conditions:default": [
            "noop_memory_monitor_factory.cc",
        ],
    }),
    hdrs = [
        "memory_monitor_factory.h",
    ],
    visibility = [
        "//src/ray/common:__subpackages__",
        "//src/ray/raylet:__subpackages__",
    ],
    deps = [
        ":memory_monitor_interface",
        "//src/ray/common/cgroup2:cgroup_manager_interface",
    ] + select({
        "//bazel:is_linux": [
            ":event_memory_monitor",
            ":memory_monitor_utils",
            ":noop_memory_monitor",
            ":threshold_memory_monitor",
            "//src/ray/common:ray_config",
            "//src/ray/util:logging",
        ],
        "//conditions:default": [
            ":noop_memory_monitor",
        ],
    }),
)
