load("//bazel:ray.bzl", "ray_cc_library")

ray_cc_library(
    name = "cpu_monitor_utils",
    srcs = [
        "cpu_monitor_utils.cc",
    ],
    hdrs = [
        "cpu_monitor_utils.h",
    ],
    visibility = [
        "//src/ray/common:__subpackages__",
    ],
    deps = [
        "//src/ray/common:status",
        "//src/ray/util:logging",
        "@com_google_absl//absl/strings",
        "@com_google_absl//absl/strings:str_format",
    ],
)

ray_cc_library(
    name = "memory_monitor_test_fixture",
    srcs = ["memory_monitor_test_fixture.cc"],
    hdrs = ["memory_monitor_test_fixture.h"],
    target_compatible_with = [
        "@platforms//os:linux",
    ],
    visibility = [
        "//src/ray/common/monitors/tests:__pkg__",
    ],
    deps = [
        ":memory_monitor_utils",
        "//src/ray/common/cgroup2:cgroup_test_utils",
        "//src/ray/util:logging",
        "@com_google_googletest//:gtest",
    ],
)

